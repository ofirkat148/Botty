# ── Google OAuth (Required for login) ───────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must include: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string
BASE_URL=http://localhost:3000

# ── LLM Provider Keys (optional — can also be set per-user in the UI) ───────
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
HYPEREAL_API_KEY=
GITHUB_API_KEY=

# ── Telegram (optional) ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
