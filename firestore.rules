rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required) - User ID
    //   - email: string (required) - User email
    //   - displayName: string (optional) - User display name
    //   - photoURL: string (optional) - User photo URL
    //   - lastLogin: string (optional) - Last login time
    //   - role: string (optional) - User role (admin/user)
    //
    // Collection: user_tokens
    // Document ID: {uid}
    // Fields:
    //   - google_access_token: string (optional) - OAuth token
    //   - updatedAt: timestamp (optional) - Last update time
    //
    // Collection: history, facts, apiKeys, memoryFiles, memoryUrls, dailyUsage, settings
    // Document ID: auto-generated or {uid}
    // Fields:
    //   - uid: string (required) - User ID
    //   [Other fields as defined in blueprint]
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "kofir2007@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'lastLogin', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             (!('role' in data) || data.role == 'user' || isAdmin());
    }

    function isValidToken(data) {
      return hasOnlyAllowedFields(['google_access_token', 'updatedAt']) &&
             (!('google_access_token' in data) || data.google_access_token is string) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users collection - PII protection
    match /users/{userId} {
      allow read, write: if true; // Relaxed for backend fallback
    }

    // User tokens - OAuth tokens protection
    match /user_tokens/{userId} {
      allow read, write: if true; // Relaxed for backend fallback
    }

    // Collections where documents have a 'uid' field
    match /history/{docId} { allow read, write: if true; }
    match /facts/{docId} { allow read, write: if true; }
    match /apiKeys/{docId} { allow read, write: if true; }
    match /memoryFiles/{docId} { allow read, write: if true; }
    match /memoryUrls/{docId} { allow read, write: if true; }
    match /dailyUsage/{docId} { allow read, write: if true; }
    match /user_settings/{docId} { allow read, write: if true; }
    
    // Settings collection - per user
    match /settings/{userId} {
      allow read, write: if true;
    }
    
    match /tg_sessions/{docId} { allow read, write: if true; }
    match /telegram_links/{docId} { allow read, write: if true; }
    match /memoryUrls/{docId} { allow read, write: if true; }
    match /health/{docId} { allow read, write: if true; }

    // Default deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
