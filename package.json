{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "npm run test:routing-unit && npm run test:agent-resolution && npm run test:chat-regression && npm run test:dashboard-smoke && npm run test:ui-agents && npm run test:memory && npm run test:provider-fallback && npm run test:agent-tools-maxturn && npm run test:telegram && npm run test:function-presets && npm run test:security && npm run test:history-archive && npm run test:memory-backup",
    "test:agent-resolution": "node --test tests/agent-resolution.test.mjs",
    "test:chat-regression": "node --test tests/chat-route.test.mjs",
    "test:dashboard-smoke": "node --test tests/dashboard-smoke.test.mjs",
    "test:function-presets": "node --test tests/function-presets.test.mjs",
    "test:ui-agents": "node --test tests/ui-agents.test.mjs",
    "test:security": "node --test tests/security.test.mjs",
    "test:memory": "node --test tests/memory-consolidation.test.mjs",
    "test:provider-fallback": "node --test tests/provider-fallback.test.mjs",
    "test:telegram": "node --test tests/telegram-status.test.mjs",
    "test:agent-tools-maxturn": "node --test tests/agent-tools-maxturn.test.mjs",
    "test:history-archive": "node --test tests/history-archive.test.mjs",
    "test:memory-backup": "node --test tests/memory-backup.test.mjs",
    "test:routing-unit": "node --test --import tsx/esm tests/routing-unit.test.mjs",
    "test:ui-features": "node --test tests/ui-features.test.mjs",
    "migrate:encrypt-keys": "node ops/migrate-encrypt-keys.mjs",
    "db:push": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^8.5.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^5.5.207",
    "pg": "^8.11.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.21.0",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.15.5",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "playwright-core": "^1.59.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
