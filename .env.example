# Database Configuration
DATABASE_PATH=./data/botty.db

# Local auth is designed for single-user local development.
LOCAL_AUTH_ENABLED=true

# Required: JWT signing secret (min 16 chars). Generate: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Required: AES-256-GCM encryption key for stored provider API keys (min 16 chars). Generate: openssl rand -hex 32
KEY_ENCRYPTION_SECRET=your-key-encryption-secret-change-this-in-production

# LLM API Keys
GEMINI_API_KEY=MY_GEMINI_API_KEY
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional local OpenAI-compatible endpoint, e.g. Ollama
LOCAL_LLM_URL=http://localhost:11434

# Network / public access
HOST=0.0.0.0
PUBLIC_BASE_URL=
CORS_ORIGINS=

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=true
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_PROVIDER=auto
TELEGRAM_MODEL=
